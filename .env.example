# Application
APP_NAME=GoodFirstFinder
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://gff_user:gff_password@db:5432/goodfirstfinder

# Security
# Gere um valor forte em produção: python -c "import secrets; print(secrets.token_hex(32))"
# Se vazio, a autenticação é desabilitada (apenas para desenvolvimento local).
API_KEY=

# GitHub
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_API_BASE_URL=

# LLM (OpenAI-compatible)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
